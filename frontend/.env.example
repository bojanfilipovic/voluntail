# Public Mapbox token (browser). Restrict by URL in Mapbox account settings.
VITE_MAPBOX_ACCESS_TOKEN=

# Canonical origin for SEO (no trailing slash). Required for accurate sitemap/robots in production builds.
# Example: https://voluntail.vercel.app or your custom domain.
VITE_SITE_ORIGIN=

# Optional: must match backend CMS_API_KEY so POST/DELETE /api/shelters succeed.
# Copy to .env.local (never commit secrets).
VITE_CMS_API_KEY=
