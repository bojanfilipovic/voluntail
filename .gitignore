# --- OS ---
.DS_Store
Thumbs.db

# --- IDEs ---
.idea/
*.iml
.project
.classpath
.settings/
*.swp
*.swo

# --- Env / secrets (keep .env.example tracked if you add one) ---
.env
.env.*
!.env.example
!backend/.env.example

# --- Gradle / Kotlin JVM (backend) ---
backend/.gradle/
**/.gradle/
build/
**/build/
out/
**/out/
**/.gradle-home/
**/.gradle-user/
# Isolated GRADLE_USER_HOME (e.g. ./gradlew with GRADLE_USER_HOME=.../gradle-local-home)
**/.gradle-local-home/

# Gradle diagnostics / problem reports (redundant with **/build/ but explicit for stragglers)
**/build/reports/problems/
**/reports/problems/
**/problems-report.html

# Kotlin Gradle plugin cache (K2, etc.)
.kotlin/

# If you keep `*.jar` ignored, always un-ignore the wrapper (reproducible builds / CI).
*.jar
!**/gradle/wrapper/gradle-wrapper.jar

*.class
*.hprof
hs_err_pid*
replay_pid*

# --- Node / Vite (frontend) ---
node_modules/
**/node_modules/
dist/
**/dist/
dist-ssr/
*.local
.vite/

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Test / coverage ---
coverage/
*.lcov
.nyc_output/

# --- Archives (optional; remove lines if you commit release artifacts) ---
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- Misc Java noise ---
*.ctxt
.mtj.tmp/

# --- Python tooling ---
.venv/
**/.venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

