# JDBC URL (Supabase Postgres). If unset or empty, the app uses in-memory sample data for shelters only.
# POST /api/suggestions returns 503 until DB_URL is set (apply peer_feedback migration).
DB_URL=
DB_PASSWORD=
DB_USERNAME=

# Max stored peer_feedback rows (spam / DB size). Default 50 when unset. Clamped 1..10000.
PEER_FEEDBACK_MAX_ROWS=

# Required for POST /api/shelters and DELETE /api/shelters/:id. If unset, mutations return 403.
# Match VITE_CMS_API_KEY in the frontend .env.local when using CMS buttons.
CMS_API_KEY=

# Comma-separated browser Origin values, e.g. http://localhost:5173,https://myapp.vercel.app
# If empty, defaults to http://localhost:5173 and http://localhost:4173 only.
CORS_ORIGINS=
