# Full JDBC URL (Supabase). Often requires TLS, e.g.:
# DATABASE_JDBC_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require&user=postgres&password=<secret>
#
# If unset or empty, the app uses in-memory sample data (no DB).
DATABASE_JDBC_URL=

# Required for POST /api/shelters and DELETE /api/shelters/:id. If unset, mutations return 403.
# Match VITE_CMS_API_KEY in the frontend .env.local when using CMS buttons.
CMS_API_KEY=
